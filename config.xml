<?xml version='1.0' encoding='utf-8'?>
<widget id="com.sunnahkkr.vpn" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Sunnahkkr VPN</name>
    <description>
        A secure, high-performance VPN application supporting WireGuard and OpenVPN protocols.
    </description>
    <author email="dev@sunnahkkr.com" href="https://sunnahkkr.com">
        Sunnahkkr VPN Team
    </author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <preference name="KeepRunning" value="true" />
</widget>
